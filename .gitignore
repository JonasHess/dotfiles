.config/argocd
.idea
/.config/github-copilot/
secrets.zsh

# Claude Code/Anthropic files
CLAUDE.local.md
.claude.json
# Ignore Claude Code runtime data, but DO track the stow-managed global config
.claude/*
!.claude/CLAUDE.md
!.claude/skills/

# General
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

clouds.yaml
/.config/xnviewmp/
auth.yml
.config/helm/

# Per-user / per-machine config — copied from the tracked *.example templates and
# never committed (see .gitconfig.local.example). Keeps personal identity and
# host-specific settings out of the shared repo.
.gitconfig.local
.zshrc.local

# Cloud & Kubernetes credentials / runtime state — never commit to dotfiles.
# (~/.config is a stow symlink into this repo, so tools write their state here.)
.config/gcloud/
.config/gh/hosts.yml
.kube/

# Tool-managed runtime state & caches written into the stowed ~/.config.
# These are large, machine-specific, and must never land in the dotfiles repo
# (e.g. nvm installs entire Node toolchains here).
.config/nvm/
.config/homebrew/
.config/iterm2/
.config/configstore/

# Gemini CLI local context
GEMINI.md

notes-local/
**/notes-local/
